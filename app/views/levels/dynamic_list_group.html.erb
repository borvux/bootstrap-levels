<%# The below code creates an array of 10 random names %>
<%= names = Array.new(10) { Faker::Name.unique.name  } %>

<div class="list-group col-md-4 offset-md-4">
  <% names.each do |name| %>
    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
      <%= name %> <span class="badge bg-primary rounded-pill"><%= rand(10) %></span>
    </a>
  <% end %>
</div>
